CONFIG_PATH=config/config.yaml

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSL_MODE=disable

DB_MAX_OPEN_CONNS=200
DB_MAX_IDLE_CONNS=15
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m

REDIS_ADDR=host:port
REDIS_PASSWORD=password
REDIS_DB=0
REDIS_TIMEOUT=5s

JWT_SECRET=SOMETHING-VERY-LONG-AND-SECRET
ACCESS_TOKEN_TTL=5m
REFRESH_TOKEN_TTL=100h